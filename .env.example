# AI provider mode
AI_STUB_MODE=false

# Gemini / Nano Banana
GEMINI_API_KEY=
# Alternative accepted aliases: GOOGLE_API_KEY or GOOGLE_GENAI_API_KEY
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_ASPECT_RATIO=1:1
GEMINI_IMAGE_SIZE=1K
# Gemini image edits can take longer than the SDK default timeout.
GEMINI_REQUEST_TIMEOUT_MS=300000
# Batch polling avoids keeping one long Gemini image connection open.
GEMINI_CONTROL_REQUEST_TIMEOUT_MS=20000
GEMINI_BATCH_POLL_INTERVAL_MS=3000
GEMINI_BATCH_MAX_WAIT_MS=180000

# App
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
NEXT_PUBLIC_SHOW_DEBUG=false
NEXT_PUBLIC_GENERATE_ENDPOINT=
NEXT_PUBLIC_GENERATE_TIMEOUT_MS=360000

# Upload and output storage
TEMP_UPLOAD_DIR=./tmp/uploads
TEMP_OUTPUT_DIR=./tmp/output
PUBLIC_GENERATED_DIR=./public/generated
GENERATED_OUTPUT_DIR=./public/generated
OUTPUT_STORAGE_MODE=filesystem
MAX_UPLOAD_SIZE_MB=4

# Optional features for later
ENABLE_BACKGROUND_REMOVAL=false
ENABLE_MASK_QA=false
