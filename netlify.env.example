# Netlify import file
# Copy or generate a local netlify.env before importing into Netlify.
# Do not commit real secrets.

# App
APP_BASE_URL=https://your-site-name.netlify.app
NODE_ENV=production
NEXT_PUBLIC_SHOW_DEBUG=false

# Local layered rendering runs in the browser; no server image-generation key is required.
MAX_UPLOAD_SIZE_MB=4
